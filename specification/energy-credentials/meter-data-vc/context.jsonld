{
    "@context": {
        "@version": 1.1,
        "@protected": true,
        "id": "@id",
        "type": "@type",
        "schema": "https://schema.org/",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "meter": "https://schema.beckn.io/meter-data-vc/vocab.jsonld#",

        "MeterDataCredential": {
            "@id": "meter:MeterDataCredential",
            "@context": {
                "@version": 1.1,
                "@protected": true,
                "id": "@id",
                "type": "@type",
                "consumerNumber": {
                    "@id": "meter:consumerNumber",
                    "@type": "xsd:string"
                },
                "meterNumber": {
                    "@id": "meter:meterNumber",
                    "@type": "xsd:string"
                },
                "serviceKind": {
                    "@id": "meter:serviceKind",
                    "@type": "xsd:string"
                },
                "timeZone": {
                    "@id": "meter:timeZone",
                    "@type": "xsd:string"
                },
                "readingType": {
                    "@id": "meter:readingType",
                    "@type": "@id",
                    "@context": {
                        "@version": 1.1,
                        "@protected": true,
                        "commodity": {
                            "@id": "meter:commodity",
                            "@type": "xsd:string"
                        },
                        "flowDirection": {
                            "@id": "meter:flowDirection",
                            "@type": "xsd:string"
                        },
                        "uom": {
                            "@id": "meter:uom",
                            "@type": "xsd:string"
                        },
                        "powerOfTenMultiplier": {
                            "@id": "meter:powerOfTenMultiplier",
                            "@type": "xsd:integer"
                        },
                        "accumulationBehaviour": {
                            "@id": "meter:accumulationBehaviour",
                            "@type": "xsd:string"
                        },
                        "intervalLength": {
                            "@id": "meter:intervalLength",
                            "@type": "xsd:integer"
                        },
                        "currency": {
                            "@id": "meter:currency",
                            "@type": "xsd:string"
                        },
                        "measurementKind": {
                            "@id": "meter:measurementKind",
                            "@type": "xsd:string"
                        },
                        "phase": {
                            "@id": "meter:phase",
                            "@type": "xsd:string"
                        }
                    }
                },
                "coveragePeriod": {
                    "@id": "meter:coveragePeriod",
                    "@type": "@id",
                    "@context": {
                        "@version": 1.1,
                        "@protected": true,
                        "start": {
                            "@id": "meter:start",
                            "@type": "xsd:dateTime"
                        },
                        "end": {
                            "@id": "meter:end",
                            "@type": "xsd:dateTime"
                        }
                    }
                },
                "qualityOfReading": {
                    "@id": "meter:qualityOfReading",
                    "@type": "xsd:string"
                },
                "intervalBlocks": {
                    "@id": "meter:intervalBlocks",
                    "@type": "@id",
                    "@container": "@set",
                    "@context": {
                        "@version": 1.1,
                        "@protected": true,
                        "interval": {
                            "@id": "meter:interval",
                            "@type": "@id",
                            "@context": {
                                "@version": 1.1,
                                "@protected": true,
                                "start": {
                                    "@id": "meter:start",
                                    "@type": "xsd:dateTime"
                                },
                                "duration": {
                                    "@id": "meter:duration",
                                    "@type": "xsd:integer"
                                }
                            }
                        },
                        "intervalReadings": {
                            "@id": "meter:intervalReadings",
                            "@type": "@id",
                            "@container": "@set",
                            "@context": {
                                "@version": 1.1,
                                "@protected": true,
                                "timePeriod": {
                                    "@id": "meter:timePeriod",
                                    "@type": "@id",
                                    "@context": {
                                        "@version": 1.1,
                                        "@protected": true,
                                        "start": {
                                            "@id": "meter:start",
                                            "@type": "xsd:dateTime"
                                        },
                                        "duration": {
                                            "@id": "meter:duration",
                                            "@type": "xsd:integer"
                                        }
                                    }
                                },
                                "value": {
                                    "@id": "meter:value",
                                    "@type": "xsd:decimal"
                                },
                                "cost": {
                                    "@id": "meter:cost",
                                    "@type": "xsd:decimal"
                                },
                                "readingQuality": {
                                    "@id": "meter:readingQuality",
                                    "@type": "xsd:string"
                                }
                            }
                        }
                    }
                }
            }
        },

        "UtilityIssuer": {
            "@id": "meter:UtilityIssuer",
            "@context": {
                "@version": 1.1,
                "@protected": true,
                "id": "@id",
                "type": "@type",
                "name": {
                    "@id": "schema:name",
                    "@type": "xsd:string"
                },
                "licenseNumber": {
                    "@id": "meter:licenseNumber",
                    "@type": "xsd:string"
                }
            }
        }
    }
}
