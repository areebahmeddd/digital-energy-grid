{
    "@context": {
        "@version": 1.1,
        "@protected": true,
        "id": "@id",
        "type": "@type",
        "schema": "https://schema.org/",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "energy": "https://nfh-trust-labs.github.io/vc-schemas/energy-credentials/electricity-credential/context.jsonld#",

        "ElectricityCredential": {
            "@id": "energy:ElectricityCredential",
            "@context": {
                "@version": 1.1,
                "@protected": true,
                "id": "@id",
                "type": "@type"
            }
        },

        "customerProfile": {
            "@id": "energy:customerProfile",
            "@type": "@id",
            "@context": {
                "@version": 1.1,
                "@protected": true,
                "customerNumber": {
                    "@id": "energy:customerNumber",
                    "@type": "xsd:string"
                },
                "meterNumber": {
                    "@id": "energy:meterNumber",
                    "@type": "xsd:string"
                },
                "meterType": {
                    "@id": "energy:meterType",
                    "@type": "xsd:string"
                },
                "maskedIdType": {
                    "@id": "energy:maskedIdType",
                    "@type": "xsd:string"
                },
                "maskedIdNumber": {
                    "@id": "energy:maskedIdNumber",
                    "@type": "xsd:string"
                }
            }
        },

        "customerDetails": {
            "@id": "energy:customerDetails",
            "@type": "@id",
            "@context": {
                "@version": 1.1,
                "@protected": true,
                "fullName": {
                    "@id": "schema:name",
                    "@type": "xsd:string"
                },
                "serviceConnectionDate": {
                    "@id": "energy:serviceConnectionDate",
                    "@type": "xsd:date"
                },
                "installationAddress": {
                    "@id": "energy:installationAddress",
                    "@type": "@id",
                    "@context": {
                        "fullAddress": {
                            "@id": "schema:streetAddress",
                            "@type": "xsd:string"
                        },
                        "city": {
                            "@id": "schema:addressLocality",
                            "@type": "xsd:string"
                        },
                        "district": {
                            "@id": "energy:district",
                            "@type": "xsd:string"
                        },
                        "stateProvince": {
                            "@id": "schema:addressRegion",
                            "@type": "xsd:string"
                        },
                        "postalCode": {
                            "@id": "schema:postalCode",
                            "@type": "xsd:string"
                        },
                        "country": {
                            "@id": "schema:addressCountry",
                            "@type": "xsd:string"
                        }
                    }
                }
            }
        },

        "consumptionProfile": {
            "@id": "energy:consumptionProfile",
            "@type": "@id",
            "@context": {
                "@version": 1.1,
                "@protected": true,
                "premisesType": {
                    "@id": "energy:premisesType",
                    "@type": "xsd:string"
                },
                "connectionType": {
                    "@id": "energy:connectionType",
                    "@type": "xsd:string"
                },
                "sanctionedLoadKW": {
                    "@id": "energy:sanctionedLoadKW",
                    "@type": "xsd:decimal"
                },
                "tariffCategoryCode": {
                    "@id": "energy:tariffCategoryCode",
                    "@type": "xsd:string"
                }
            }
        },

        "generationProfile": {
            "@id": "energy:generationProfile",
            "@type": "@id",
            "@context": {
                "@version": 1.1,
                "@protected": true,
                "assetId": {
                    "@id": "energy:assetId",
                    "@type": "xsd:string"
                },
                "generationType": {
                    "@id": "energy:generationType",
                    "@type": "xsd:string"
                },
                "capacityKW": {
                    "@id": "energy:capacityKW",
                    "@type": "xsd:decimal"
                },
                "commissioningDate": {
                    "@id": "energy:commissioningDate",
                    "@type": "xsd:date"
                },
                "manufacturer": {
                    "@id": "schema:manufacturer",
                    "@type": "xsd:string"
                },
                "modelNumber": {
                    "@id": "energy:modelNumber",
                    "@type": "xsd:string"
                }
            }
        },

        "storageProfile": {
            "@id": "energy:storageProfile",
            "@type": "@id",
            "@context": {
                "@version": 1.1,
                "@protected": true,
                "assetId": {
                    "@id": "energy:storageAssetId",
                    "@type": "xsd:string"
                },
                "storageCapacityKWh": {
                    "@id": "energy:storageCapacityKWh",
                    "@type": "xsd:decimal"
                },
                "powerRatingKW": {
                    "@id": "energy:powerRatingKW",
                    "@type": "xsd:decimal"
                },
                "commissioningDate": {
                    "@id": "energy:storageCommissioningDate",
                    "@type": "xsd:date"
                },
                "storageType": {
                    "@id": "energy:storageType",
                    "@type": "xsd:string"
                }
            }
        },

        "UtilityIssuer": {
            "@id": "energy:UtilityIssuer",
            "@context": {
                "@version": 1.1,
                "@protected": true,
                "id": "@id",
                "type": "@type",
                "name": {
                    "@id": "schema:name",
                    "@type": "xsd:string"
                },
                "licenseNumber": {
                    "@id": "energy:licenseNumber",
                    "@type": "xsd:string"
                }
            }
        }
    }
}
