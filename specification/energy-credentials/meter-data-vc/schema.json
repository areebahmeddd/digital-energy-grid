{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://nfh-trust-labs.github.io/vc-schemas/energy-credentials/meter-data-vc/schema.json",
    "title": "Meter Data Credential Schema",
    "description": "JSON Schema for the Meter Data Verifiable Credential. Contains historical time-series interval meter readings aligned with Green Button (ESPI/NAESB) semantics.  Issued by the utility; consumed by trading apps for demand forecasting.\n",
    "type": "object",
    "required": [
        "@context",
        "id",
        "type",
        "issuer",
        "issuanceDate",
        "credentialSubject"
    ],
    "properties": {
        "@context": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "contains": {
                "const": "https://www.w3.org/2018/credentials/v1"
            },
            "minItems": 2
        },
        "id": {
            "type": "string",
            "format": "uri",
            "pattern": "^urn:uuid:[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
            "description": "Unique identifier for the credential in URN UUID format"
        },
        "type": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "contains": {
                "const": "MeterDataCredential"
            },
            "minItems": 2
        },
        "issuer": {
            "type": "object",
            "required": [
                "id",
                "name",
                "licenseNumber"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uri",
                    "description": "DID of the issuing distribution utility"
                },
                "name": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Name of the distribution utility"
                },
                "licenseNumber": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Regulatory license number issued by the local energy regulator"
                }
            }
        },
        "issuanceDate": {
            "type": "string",
            "format": "date-time",
            "description": "Date and time when the credential was issued"
        },
        "expirationDate": {
            "type": "string",
            "format": "date-time",
            "description": "Optional expiration date of the credential"
        },
        "credentialStatus": {
            "type": "object",
            "required": [
                "id",
                "type"
            ],
            "description": "Revocation status information for the credential",
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL to query the revocation status via DeDi registry"
                },
                "type": {
                    "type": "string",
                    "const": "dediregistry",
                    "description": "Type of status check mechanism (DeDi Registry)"
                }
            }
        },
        "credentialSubject": {
            "type": "object",
            "description": "Historical meter reading data for a single meter, using Green Button (ESPI/NAESB) semantics.\n",
            "required": [
                "id",
                "consumerNumber",
                "meterNumber",
                "serviceKind",
                "timeZone",
                "readingType",
                "coveragePeriod",
                "intervalBlocks"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uri",
                    "description": "DID of the customer / credential subject"
                },
                "consumerNumber": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Utility account number (links to the customer record; reused from Utility Customer Credential)\n"
                },
                "meterNumber": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 50,
                    "description": "Meter serial number (links to the physical meter; reused from Utility Customer Credential)\n"
                },
                "serviceKind": {
                    "type": "string",
                    "description": "Kind of service provided (ESPI: ServiceKind). ESPI codes \u2014 0: electricity, 1: gas, 2: water.\n",
                    "enum": [
                        "electricity",
                        "gas",
                        "water"
                    ]
                },
                "timeZone": {
                    "type": "string",
                    "description": "IANA time-zone identifier for the meter location (e.g., \"Asia/Kolkata\").  Critical for demand-forecasting models that need local solar time.\n",
                    "examples": [
                        "Asia/Kolkata",
                        "America/New_York"
                    ]
                },
                "readingType": {
                    "type": "object",
                    "description": "Describes what is being measured (ESPI: ReadingType). Each field maps to a Green Button ReadingType sub-element.\n",
                    "required": [
                        "commodity",
                        "flowDirection",
                        "uom",
                        "accumulationBehaviour",
                        "intervalLength"
                    ],
                    "properties": {
                        "commodity": {
                            "type": "string",
                            "description": "Commodity being metered (ESPI: CommodityKind). ESPI codes \u2014 0: none, 1: electricitySecondaryMetered, 2: electricityPrimaryMetered, 4: air, 7: naturalGas, 8: propane, 9: potableWater, 10: steam, 11: wasteWater.\n",
                            "enum": [
                                "none",
                                "electricitySecondaryMetered",
                                "electricityPrimaryMetered",
                                "air",
                                "naturalGas",
                                "propane",
                                "potableWater",
                                "steam",
                                "wasteWater"
                            ]
                        },
                        "flowDirection": {
                            "type": "string",
                            "description": "Direction of energy flow being measured (ESPI: FlowDirectionKind). ESPI codes \u2014 0: none, 1: forward, 2: lagging, 3: leading, 4: net, 5: q1plusQ2, 19: reverse.\n",
                            "enum": [
                                "none",
                                "forward",
                                "reverse",
                                "net",
                                "lagging",
                                "leading"
                            ]
                        },
                        "uom": {
                            "type": "string",
                            "description": "Unit of measure for the reading (ESPI: UnitOfMeasure / UOM). ESPI codes \u2014 5: A (current), 29: V (voltage), 31: J, 33: Hz, 38: W (real power), 42: m3, 61: VA, 63: VAr, 71: Wh (real energy), 72: kWh.\n",
                            "enum": [
                                "Wh",
                                "kWh",
                                "W",
                                "kW",
                                "VA",
                                "VAr",
                                "V",
                                "A",
                                "Hz",
                                "J",
                                "m3"
                            ]
                        },
                        "powerOfTenMultiplier": {
                            "type": "integer",
                            "default": 0,
                            "description": "Power-of-ten multiplier applied to the reading value (ESPI: UnitMultiplierKind). E.g., 0 = \u00d71, 3 = \u00d71000 (kilo), -3 = \u00d70.001 (milli). When value is a decimal, this SHOULD be 0 or omitted.\n"
                        },
                        "accumulationBehaviour": {
                            "type": "string",
                            "description": "How the reading value accumulates over time (ESPI: AccumulationBehaviourKind). ESPI codes \u2014 0: none, 1: bulkQuantity, 2: continuousCumulative, 3: cumulative, 4: deltaData, 6: indicating, 9: summation, 12: instantaneous.\n",
                            "enum": [
                                "none",
                                "bulkQuantity",
                                "continuousCumulative",
                                "cumulative",
                                "deltaData",
                                "indicating",
                                "summation",
                                "instantaneous"
                            ]
                        },
                        "intervalLength": {
                            "type": "integer",
                            "minimum": 1,
                            "description": "Standard interval length in seconds for the readings (e.g., 900 for 15-minute intervals).\n"
                        },
                        "currency": {
                            "type": "string",
                            "description": "ISO 4217 currency code for cost values in interval readings (ESPI: currency). Required when cost data is present in readings.\n",
                            "examples": [
                                "USD",
                                "EUR",
                                "INR"
                            ]
                        },
                        "measurementKind": {
                            "type": "string",
                            "description": "What the reading measures (ESPI: MeasurementKind / kind). Distinguishes energy from demand, power, voltage, etc. ESPI codes — 0: none, 2: apparentPowerFactor, 3: currency, 4: current, 5: currentAngle, 7: date, 8: demand, 9: distance, 12: energy, 13: energizationLoadSide, 14: fan, 15: frequency, 35: power, 37: powerFactor, 38: quantityPower, 40: voltage, 41: volumetricFlow.\n",
                            "enum": [
                                "none",
                                "energy",
                                "demand",
                                "power",
                                "current",
                                "voltage",
                                "frequency",
                                "powerFactor",
                                "apparentPowerFactor",
                                "quantityPower",
                                "volumetricFlow",
                                "currency",
                                "date",
                                "distance",
                                "energizationLoadSide",
                                "fan"
                            ]
                        },
                        "phase": {
                            "type": "string",
                            "description": "Electrical phase being measured (ESPI: PhaseCodeKind). Relevant for three-phase commercial/industrial meters. ESPI codes — 0: notApplicable, 16: phaseAN, 32: phaseBN, 64: phaseCN, 128: phaseAB, 256: phaseBC, 512: phaseCA, 768: phaseABC.\n",
                            "enum": [
                                "notApplicable",
                                "phaseAN",
                                "phaseBN",
                                "phaseCN",
                                "phaseAB",
                                "phaseBC",
                                "phaseCA",
                                "phaseABC"
                            ]
                        }
                    }
                },
                "coveragePeriod": {
                    "type": "object",
                    "description": "Summary date range of the data contained in this credential.\n",
                    "required": [
                        "start",
                        "end"
                    ],
                    "properties": {
                        "start": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Start of the coverage period (ISO 8601)"
                        },
                        "end": {
                            "type": "string",
                            "format": "date-time",
                            "description": "End of the coverage period (ISO 8601)"
                        }
                    }
                },
                "qualityOfReading": {
                    "type": "string",
                    "description": "Overall quality of the reading data in this credential (ESPI: QualityOfReading). ESPI codes — 0: valid, 7: manuallyEdited, 8: estimatedUsingReferenceDay, 9: estimatedUsingLinearInterpolation, 10: questionable, 11: derived, 12: projected, 13: mixed, 14: raw, 15: normalizedForWeather, 16: other, 17: validated, 18: verified.\n",
                    "enum": [
                        "valid",
                        "manuallyEdited",
                        "estimatedUsingReferenceDay",
                        "estimatedUsingLinearInterpolation",
                        "questionable",
                        "derived",
                        "projected",
                        "mixed",
                        "raw",
                        "normalizedForWeather",
                        "other",
                        "validated",
                        "verified"
                    ]
                },
                "intervalBlocks": {
                    "type": "array",
                    "minItems": 1,
                    "description": "Array of interval blocks containing the actual meter readings. Each block covers a contiguous time span.\n",
                    "items": {
                        "type": "object",
                        "description": "A contiguous block of interval readings (ESPI: IntervalBlock).\n",
                        "required": [
                            "interval",
                            "intervalReadings"
                        ],
                        "properties": {
                            "interval": {
                                "type": "object",
                                "description": "A time interval defined by a start timestamp and a duration in seconds (ESPI: DateTimeInterval).\n",
                                "required": [
                                    "start",
                                    "duration"
                                ],
                                "properties": {
                                    "start": {
                                        "type": "string",
                                        "format": "date-time",
                                        "description": "Start of the interval (ISO 8601)"
                                    },
                                    "duration": {
                                        "type": "integer",
                                        "minimum": 0,
                                        "description": "Duration of the interval in seconds"
                                    }
                                }
                            },
                            "intervalReadings": {
                                "type": "array",
                                "minItems": 1,
                                "items": {
                                    "type": "object",
                                    "description": "A single metered reading within a block (ESPI: IntervalReading).\n",
                                    "required": [
                                        "timePeriod",
                                        "value"
                                    ],
                                    "properties": {
                                        "timePeriod": {
                                            "type": "object",
                                            "description": "A time interval defined by a start timestamp and a duration in seconds (ESPI: DateTimeInterval).\n",
                                            "required": [
                                                "start",
                                                "duration"
                                            ],
                                            "properties": {
                                                "start": {
                                                    "type": "string",
                                                    "format": "date-time",
                                                    "description": "Start of the interval (ISO 8601)"
                                                },
                                                "duration": {
                                                    "type": "integer",
                                                    "minimum": 0,
                                                    "description": "Duration of the interval in seconds"
                                                }
                                            }
                                        },
                                        "value": {
                                            "type": "number",
                                            "description": "Reading value.  May be an integer (Green Button compatible) or a decimal for direct physical representation.  When an integer, multiply by 10^powerOfTenMultiplier and apply the UOM from ReadingType to get the physical quantity.  When a decimal, powerOfTenMultiplier SHOULD be 0 (or omitted) and the value represents the physical quantity directly in the given UOM.\n"
                                        },
                                        "cost": {
                                            "type": "number",
                                            "description": "Cost for this interval in the currency specified by readingType.currency (ESPI: IntervalReading.cost). In integer mode (Green Button compatible), the value is in thousandths of the currency unit (e.g., 4639 = $4.639 USD). In decimal mode, the value represents the cost directly in the currency unit.\n"
                                        },
                                        "readingQuality": {
                                            "type": "string",
                                            "description": "Quality of this specific reading (ESPI: ReadingQuality). Overrides the credential-level qualityOfReading for this interval.\n",
                                            "enum": [
                                                "valid",
                                                "manuallyEdited",
                                                "estimatedUsingReferenceDay",
                                                "estimatedUsingLinearInterpolation",
                                                "questionable",
                                                "derived",
                                                "projected",
                                                "raw",
                                                "normalizedForWeather",
                                                "other",
                                                "validated",
                                                "verified"
                                            ]
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "proof": {
            "type": "object",
            "required": [
                "type",
                "created",
                "verificationMethod",
                "proofPurpose",
                "proofValue"
            ],
            "properties": {
                "type": {
                    "type": "string",
                    "description": "Cryptographic signature type (e.g., Ed25519Signature2020)"
                },
                "created": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Timestamp when the proof was created"
                },
                "verificationMethod": {
                    "type": "string",
                    "format": "uri",
                    "description": "URI of the verification method / public key"
                },
                "proofPurpose": {
                    "type": "string",
                    "enum": [
                        "assertionMethod",
                        "authentication"
                    ],
                    "description": "Purpose of the proof"
                },
                "proofValue": {
                    "type": "string",
                    "minLength": 1,
                    "description": "The cryptographic signature value"
                }
            }
        }
    }
}