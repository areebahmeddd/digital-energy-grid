{
    "@context": {
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "schema": "https://schema.org/",
        "espi": "http://naesb.org/espi#",
        "billing": "https://nfh-trust-labs.github.io/vc-schemas/energy-credentials/billing-summary-vc/vocab.jsonld#"
    },
    "@graph": [
        {
            "@id": "billing:BillingSummaryCredential",
            "@type": "rdfs:Class",
            "rdfs:label": "Billing Summary Credential",
            "rdfs:comment": "A W3C Verifiable Credential containing aggregated billing period data with costs and consumption totals, aligned with Green Button (ESPI/NAESB) UsageSummary semantics."
        },
        {
            "@id": "billing:BillingPeriod",
            "@type": "rdfs:Class",
            "rdfs:label": "Billing Period",
            "rdfs:comment": "A single billing cycle summary with cost and consumption data. Maps to ESPI UsageSummary + billing-granularity IntervalReading.",
            "rdfs:seeAlso": { "@id": "espi:UsageSummary" }
        },
        {
            "@id": "billing:DateTimeInterval",
            "@type": "rdfs:Class",
            "rdfs:label": "Date Time Interval",
            "rdfs:comment": "A time interval defined by a start timestamp and duration. Maps to ESPI DateTimeInterval.",
            "rdfs:seeAlso": { "@id": "espi:DateTimeInterval" }
        },
        {
            "@id": "billing:CoveragePeriod",
            "@type": "rdfs:Class",
            "rdfs:label": "Coverage Period",
            "rdfs:comment": "A summary date range defined by start and end timestamps."
        },
        {
            "@id": "billing:Consumption",
            "@type": "rdfs:Class",
            "rdfs:label": "Consumption",
            "rdfs:comment": "A consumption measurement with value, unit of measure, and optional scale factor. Maps to ESPI SummaryMeasurement.",
            "rdfs:seeAlso": { "@id": "espi:SummaryMeasurement" }
        },

        {
            "@id": "billing:consumerNumber",
            "@type": "rdf:Property",
            "rdfs:label": "consumer number",
            "rdfs:comment": "Utility account number linking to the customer record.",
            "rdfs:domain": { "@id": "billing:BillingSummaryCredential" },
            "rdfs:range": { "@id": "xsd:string" }
        },
        {
            "@id": "billing:meterNumber",
            "@type": "rdf:Property",
            "rdfs:label": "meter number",
            "rdfs:comment": "Meter serial number linking to the physical meter.",
            "rdfs:domain": { "@id": "billing:BillingSummaryCredential" },
            "rdfs:range": { "@id": "xsd:string" }
        },
        {
            "@id": "billing:serviceKind",
            "@type": "rdf:Property",
            "rdfs:label": "service kind",
            "rdfs:comment": "Kind of service (electricity, gas, water). Maps to ESPI ServiceKind.",
            "rdfs:domain": { "@id": "billing:BillingSummaryCredential" },
            "rdfs:range": { "@id": "xsd:string" },
            "rdfs:seeAlso": { "@id": "espi:ServiceKind" }
        },
        {
            "@id": "billing:timeZone",
            "@type": "rdf:Property",
            "rdfs:label": "time zone",
            "rdfs:comment": "IANA time-zone identifier for the meter location.",
            "rdfs:domain": { "@id": "billing:BillingSummaryCredential" },
            "rdfs:range": { "@id": "xsd:string" }
        },
        {
            "@id": "billing:currency",
            "@type": "rdf:Property",
            "rdfs:label": "currency",
            "rdfs:comment": "ISO 4217 currency code for all monetary values.",
            "rdfs:domain": { "@id": "billing:BillingSummaryCredential" },
            "rdfs:range": { "@id": "xsd:string" }
        },
        {
            "@id": "billing:coveragePeriod",
            "@type": "rdf:Property",
            "rdfs:label": "coverage period",
            "rdfs:comment": "Summary date range of the billing data.",
            "rdfs:domain": { "@id": "billing:BillingSummaryCredential" },
            "rdfs:range": { "@id": "billing:CoveragePeriod" }
        },
        {
            "@id": "billing:billingPeriods",
            "@type": "rdf:Property",
            "rdfs:label": "billing periods",
            "rdfs:comment": "Array of billing period summaries.",
            "rdfs:domain": { "@id": "billing:BillingSummaryCredential" },
            "rdfs:range": { "@id": "billing:BillingPeriod" }
        },
        {
            "@id": "billing:period",
            "@type": "rdf:Property",
            "rdfs:label": "period",
            "rdfs:comment": "Billing period boundaries. Maps to ESPI billingPeriod.",
            "rdfs:domain": { "@id": "billing:BillingPeriod" },
            "rdfs:range": { "@id": "billing:DateTimeInterval" },
            "rdfs:seeAlso": { "@id": "espi:billingPeriod" }
        },
        {
            "@id": "billing:billAmount",
            "@type": "rdf:Property",
            "rdfs:label": "bill amount",
            "rdfs:comment": "Total bill amount for a billing period. Maps to ESPI billLastPeriod.",
            "rdfs:domain": { "@id": "billing:BillingPeriod" },
            "rdfs:range": { "@id": "xsd:decimal" },
            "rdfs:seeAlso": { "@id": "espi:billLastPeriod" }
        },
        {
            "@id": "billing:consumption",
            "@type": "rdf:Property",
            "rdfs:label": "consumption",
            "rdfs:comment": "Total consumption for a billing period. Maps to ESPI overallConsumptionLastPeriod.",
            "rdfs:domain": { "@id": "billing:BillingPeriod" },
            "rdfs:range": { "@id": "billing:Consumption" },
            "rdfs:seeAlso": { "@id": "espi:overallConsumptionLastPeriod" }
        },
        {
            "@id": "billing:additionalCosts",
            "@type": "rdf:Property",
            "rdfs:label": "additional costs",
            "rdfs:comment": "Additional charges, surcharges, or fees. Maps to ESPI costAdditionalLastPeriod.",
            "rdfs:domain": { "@id": "billing:BillingPeriod" },
            "rdfs:range": { "@id": "xsd:decimal" },
            "rdfs:seeAlso": { "@id": "espi:costAdditionalLastPeriod" }
        },
        {
            "@id": "billing:qualityOfReading",
            "@type": "rdf:Property",
            "rdfs:label": "quality of reading",
            "rdfs:comment": "Quality of the reading data for a billing period. Maps to ESPI QualityOfReading.",
            "rdfs:domain": { "@id": "billing:BillingPeriod" },
            "rdfs:range": { "@id": "xsd:string" },
            "rdfs:seeAlso": { "@id": "espi:QualityOfReading" }
        },
        {
            "@id": "billing:value",
            "@type": "rdf:Property",
            "rdfs:label": "value",
            "rdfs:comment": "Consumption value.",
            "rdfs:domain": { "@id": "billing:Consumption" },
            "rdfs:range": { "@id": "xsd:decimal" }
        },
        {
            "@id": "billing:uom",
            "@type": "rdf:Property",
            "rdfs:label": "unit of measure",
            "rdfs:comment": "Unit of measure for consumption.",
            "rdfs:domain": { "@id": "billing:Consumption" },
            "rdfs:range": { "@id": "xsd:string" }
        },
        {
            "@id": "billing:powerOfTenMultiplier",
            "@type": "rdf:Property",
            "rdfs:label": "power of ten multiplier",
            "rdfs:comment": "Power-of-ten multiplier for the consumption value.",
            "rdfs:domain": { "@id": "billing:Consumption" },
            "rdfs:range": { "@id": "xsd:integer" }
        },
        {
            "@id": "billing:LineItem",
            "@type": "rdfs:Class",
            "rdfs:label": "Line Item",
            "rdfs:comment": "A single charge or credit line item within a billing period. Maps to ESPI LineItem.",
            "rdfs:seeAlso": { "@id": "espi:LineItem" }
        },
        {
            "@id": "billing:ItemKindEnum",
            "@type": "rdfs:Class",
            "rdfs:label": "Item Kind",
            "rdfs:comment": "Enumeration of line item types: energyGenerationFee, energyDeliveryFee, energyUsageFee, administrativeFee, tax, energyGenerationCredit, energyDeliveryCredit, administrativeCredit, payment, information."
        },
        {
            "@id": "billing:lineItems",
            "@type": "rdf:Property",
            "rdfs:label": "line items",
            "rdfs:comment": "Itemised breakdown of charges and credits for a billing period. Maps to ESPI costAdditionalDetailLastPeriod.",
            "rdfs:domain": { "@id": "billing:BillingPeriod" },
            "rdfs:range": { "@id": "billing:LineItem" },
            "rdfs:seeAlso": { "@id": "espi:costAdditionalDetailLastPeriod" }
        },
        {
            "@id": "billing:itemKind",
            "@type": "rdf:Property",
            "rdfs:label": "item kind",
            "rdfs:comment": "Classification of the charge or credit. Maps to ESPI ItemKind.",
            "rdfs:domain": { "@id": "billing:LineItem" },
            "rdfs:range": { "@id": "billing:ItemKindEnum" },
            "rdfs:seeAlso": { "@id": "espi:ItemKind" }
        },
        {
            "@id": "billing:amount",
            "@type": "rdf:Property",
            "rdfs:label": "amount",
            "rdfs:comment": "Monetary amount for a line item. Negative values represent credits.",
            "rdfs:domain": { "@id": "billing:LineItem" },
            "rdfs:range": { "@id": "xsd:decimal" }
        },
        {
            "@id": "billing:note",
            "@type": "rdf:Property",
            "rdfs:label": "note",
            "rdfs:comment": "Human-readable description of a line item.",
            "rdfs:domain": { "@id": "billing:LineItem" },
            "rdfs:range": { "@id": "xsd:string" }
        },
        {
            "@id": "billing:unitCost",
            "@type": "rdf:Property",
            "rdfs:label": "unit cost",
            "rdfs:comment": "Per-unit cost for a line item (e.g., price per kWh).",
            "rdfs:domain": { "@id": "billing:LineItem" },
            "rdfs:range": { "@id": "xsd:decimal" }
        },
        {
            "@id": "billing:itemPeriod",
            "@type": "rdf:Property",
            "rdfs:label": "item period",
            "rdfs:comment": "Time period a line item covers, if different from the billing period. Maps to ESPI LineItem.itemPeriod.",
            "rdfs:domain": { "@id": "billing:LineItem" },
            "rdfs:range": { "@id": "billing:DateTimeInterval" },
            "rdfs:seeAlso": { "@id": "espi:itemPeriod" }
        },

        {
            "@id": "billing:start",
            "@type": "rdf:Property",
            "rdfs:label": "start",
            "rdfs:comment": "Start timestamp of an interval or period.",
            "rdfs:range": { "@id": "xsd:dateTime" }
        },
        {
            "@id": "billing:end",
            "@type": "rdf:Property",
            "rdfs:label": "end",
            "rdfs:comment": "End timestamp of a coverage period.",
            "rdfs:range": { "@id": "xsd:dateTime" }
        },
        {
            "@id": "billing:duration",
            "@type": "rdf:Property",
            "rdfs:label": "duration",
            "rdfs:comment": "Duration of an interval in seconds.",
            "rdfs:range": { "@id": "xsd:integer" }
        },
        {
            "@id": "billing:licenseNumber",
            "@type": "rdf:Property",
            "rdfs:label": "license number",
            "rdfs:comment": "Regulatory license number of the issuing utility.",
            "rdfs:range": { "@id": "xsd:string" }
        }
    ]
}
