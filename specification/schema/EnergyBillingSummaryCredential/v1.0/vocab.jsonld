{
    "@context": {
        "@version": 1.1,
        "energy": "https://schema.beckn.io/energy/",
        "energyCred": "https://schema.beckn.io/deg/EnergyCredential/v2.0/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "energy:EnergyBillingSummaryCredential",
            "@type": "rdfs:Class",
            "rdfs:label": "Energy Billing Summary Credential",
            "rdfs:comment": "A W3C Verifiable Credential containing aggregated billing period data using ESPI/Green Button types. Subclass of EnergyCredential.",
            "rdfs:subClassOf": { "@id": "energyCred:EnergyCredential" }
        },
        {
            "@id": "energy:credentialSubject",
            "@type": "rdf:Property",
            "rdfs:label": "Credential subject",
            "rdfs:comment": "The subject of an energy billing summary verifiable credential, containing customer profile and billing data."
        }
    ]
}
