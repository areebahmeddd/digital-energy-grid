{
    "@context": [
        "https://schema.beckn.io/external/espi/context.jsonld",
        {
            "@version": 1.1,
            "@protected": true,
            "id": "@id",
            "type": "@type",
            "schema": "https://schema.org/",
            "xsd": "http://www.w3.org/2001/XMLSchema#",
            "energy": "https://schema.beckn.io/energy/",

            "MeterDataCredential": {
                "@id": "energy:MeterDataCredential",
                "@context": {
                    "@version": 1.1,
                    "@protected": true,
                    "id": "@id",
                    "type": "@type",
                    "customerProfile": {
                        "@id": "energy:customerProfile",
                        "@type": "@id",
                        "@context": {
                            "@version": 1.1,
                            "@protected": true,
                            "customerNumber": {
                                "@id": "energy:customerNumber",
                                "@type": "xsd:string"
                            },
                            "meterNumber": {
                                "@id": "energy:meterNumber",
                                "@type": "xsd:string"
                            },
                            "meterType": {
                                "@id": "energy:meterType",
                                "@type": "xsd:string"
                            },
                            "maskedIdType": {
                                "@id": "energy:maskedIdType",
                                "@type": "xsd:string"
                            },
                            "maskedIdNumber": {
                                "@id": "energy:maskedIdNumber",
                                "@type": "xsd:string"
                            }
                        }
                    },
                    "meterDataGB": {
                        "@id": "energy:meterDataGB",
                        "@type": "@id",
                        "@context": {
                            "@version": 1.1,
                            "@protected": true,
                            "timeZone": {
                                "@id": "energy:timeZone",
                                "@type": "xsd:string"
                            }
                        }
                    }
                }
            },

            "idRef": {
                "@id": "energy:idRef",
                "@context": {
                    "@version": 1.1,
                    "@protected": true,
                    "issuedBy": {
                        "@id": "energy:issuedBy",
                        "@type": "@id"
                    },
                    "subjectId": {
                        "@id": "energy:subjectId",
                        "@type": "xsd:string"
                    }
                }
            }
        }
    ]
}
