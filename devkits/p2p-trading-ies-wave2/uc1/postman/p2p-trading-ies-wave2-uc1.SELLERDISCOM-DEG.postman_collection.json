              "mode": "raw",
              "raw": "{\n  \"context\": {\n    \"networkId\": \"{{domain}}\",\n    \"version\": \"{{version}}\",\n    \"action\": \"on_status\",\n    \"bapId\": \"{{bap_id}}\",\n    \"bapUri\": \"{{bap_host_root}}/bap/receiver\",\n    \"bppId\": \"{{bpp_id}}\",\n    \"bppUri\": \"{{bpp_host_root}}/bpp/caller\",\n    \"transactionId\": \"{{transaction_id}}\",\n    \"messageId\": \"{{$guid}}\",\n    \"timestamp\": \"{{iso_date}}\",\n    \"schemaContext\": [\"https://schema.beckn.io/DatasetItem/1.1/context.jsonld\", \"https://schema.beckn.io/BecknTimeSeries/v1.0/context.jsonld\"]\n  },\n  \"message\": {\n    \"contract\": {\n      \"id\": \"contract-p2p-001\",\n      \"status\": {\"code\": \"ACTIVE\"},\n      \"commitments\": [\n        {\n          \"id\": \"commitment-p2p-001\",\n          \"status\": {\"descriptor\": {\"code\": \"ACTIVE\"}},\n          \"resources\": [\n            {\n              \"id\": \"ds-actuals-001\",\n              \"descriptor\": {\"name\": \"Seller-discom meter actuals\"},\n              \"quantity\": {\"@type\": \"Quantity\", \"unitText\": \"report\", \"unitCode\": \"EA\", \"value\": \"1\"},\n              \"resourceAttributes\": {\n                \"@context\": \"https://schema.beckn.io/DatasetItem/1.1/context.jsonld\",\n                \"@type\": \"DatasetItem\",\n                \"schema:identifier\": \"ds-actuals-001\",\n                \"schema:name\": \"Seller-discom meter actuals\",\n                \"schema:temporalCoverage\": \"2026-04-26T04:30:00Z/2026-04-26T05:30:00Z\",\n                \"dataPayload\": {\n                  \"@context\": \"https://schema.beckn.io/BecknTimeSeries/v1.0/context.jsonld\",\n                  \"@type\": \"TimeSeries\",\n                  \"resourceName\": \"TEST_METER_SELLER_001\",\n                  \"clientName\": \"TEST_DISCOM_SELLER\",\n                  \"intervalPeriod\": {\"start\": \"2026-04-26T04:30:00Z\", \"duration\": \"PT1H\"},\n                  \"payloadDescriptors\": [{\"objectType\": \"REPORT_PAYLOAD_DESCRIPTOR\", \"payloadType\": \"ENERGY_CONSUMPTION\", \"units\": \"KWH\"}],\n                  \"intervals\": [{\"id\": 0, \"payloads\": [{\"type\": \"ENERGY_CONSUMPTION\", \"values\": [-19.2]}]}]\n                }\n              }\n            }\n          ],\n          \"offer\": {\"id\": \"offer-001\", \"resourceIds\": [\"ds-actuals-001\"]}\n        }\n      ]\n    }\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{sellerdiscom_bpp_caller_url}}/on_status",
