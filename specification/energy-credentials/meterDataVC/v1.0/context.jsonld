{
    "@context": [
        "https://schema.beckn.io/external/espi/context.jsonld",
        "https://schema.beckn.io/EnergyCustomerProfile/context.jsonld",
        {
            "@version": 1.1,
            "@protected": true,
            "id": "@id",
            "type": "@type",
            "schema": "https://schema.org/",
            "xsd": "http://www.w3.org/2001/XMLSchema#",
            "energy": "https://schema.beckn.io/energy/",

            "MeterDataCredential": {
                "@id": "energy:MeterDataCredential",
                "@context": {
                    "@version": 1.1,
                    "@protected": true,
                    "id": "@id",
                    "type": "@type",
                    "meterDataGB": {
                        "@id": "energy:meterDataGB",
                        "@type": "@id",
                        "@context": {
                            "@version": 1.1,
                            "@protected": true,
                            "timeZone": {
                                "@id": "energy:timeZone",
                                "@type": "xsd:string"
                            }
                        }
                    }
                }
            }
        }
    ]
}
