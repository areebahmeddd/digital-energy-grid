            "body": {
              "mode": "raw",
              "raw": "{\n  \"context\": {\n    \"networkId\": \"nfh.global/testnet-deg\",\n    \"version\": \"{{version}}\",\n    \"action\": \"on_status\",\n    \"bapId\": \"{{bap_id}}\",\n    \"bapUri\": \"{{bap_host_root}}/bap/receiver\",\n    \"bppId\": \"{{bpp_id}}\",\n    \"bppUri\": \"{{bpp_host_root}}/bpp/caller\",\n    \"transactionId\": \"{{transaction_id}}\",\n    \"messageId\": \"{{$guid}}\",\n    \"timestamp\": \"{{iso_date}}\",\n    \"schemaContext\": [\n      \"https://schema.beckn.io/EnergyTradeOffer/v2.0/context.jsonld\",\n      \"https://schema.beckn.io/DEGContract/v2.0/context.jsonld\",\n      \"https://schema.beckn.io/EnergyCustomer/v2.0/context.jsonld\",\n      \"https://schema.beckn.io/BecknTimeSeries/v1.0/context.jsonld\",\n      \"https://schema.beckn.io/DiscomLedgerProvider/v1.0/context.jsonld\"\n    ]\n  },\n  \"message\": {\n    \"contract\": {\n      \"id\": \"contract-p2p-001\",\n      \"status\": {\n        \"code\": \"ACTIVE\"\n      },\n      \"commitments\": [\n        {\n          \"id\": \"commitment-p2p-001\",\n          \"status\": {\n            \"descriptor\": {\n              \"code\": \"ACTIVE\"\n            }\n          },\n          \"resources\": [\n            {\n              \"id\": \"energy-resource-solar-001\",\n              \"descriptor\": {\n                \"name\": \"Solar energy slot \\u2014 2026-04-26 10:00\\u201312:00 IST\"\n              },\n              \"quantity\": {\n                \"@type\": \"Quantity\",\n                \"unitCode\": \"KWH\",\n                \"unitQuantity\": 35.0\n              },\n              \"resourceAttributes\": {\n                \"@context\": \"https://schema.beckn.io/EnergyResource/v2.0/context.jsonld\",\n                \"@type\": \"EnergyResource\",\n                \"resourceType\": \"SOLAR\",\n                \"resourceId\": \"TEST_METER_SELLER_001\"\n              }\n            }\n          ],\n          \"offer\": {\n            \"id\": \"offer-p2p-001\",\n            \"resourceIds\": [\"energy-resource-solar-001\"]\n          },\n          \"commitmentAttributes\": {\n            \"@context\": \"https://schema.beckn.io/BecknTimeSeries/v1.0/context.jsonld\",\n            \"@type\": \"TimeSeries\",\n            \"intervalPeriod\": {\n              \"start\": \"2026-04-26T04:30:00Z\",\n              \"duration\": \"PT1H\"\n            },\n            \"payloadDescriptors\": [\n              {\"objectType\": \"REPORT_PAYLOAD_DESCRIPTOR\", \"payloadType\": \"BUYER_DISCOM_ALLOC\", \"units\": \"KWH\"},\n              {\"objectType\": \"REPORT_PAYLOAD_DESCRIPTOR\", \"payloadType\": \"BUYER_DISCOM_STATUS\", \"units\": \"STRING\"}\n            ],\n            \"intervals\": [\n              {\"id\": 0, \"payloads\": [{\"type\": \"BUYER_DISCOM_ALLOC\", \"values\": [18.5]}, {\"type\": \"BUYER_DISCOM_STATUS\", \"values\": [\"COMPLETED\"]}]},\n              {\"id\": 1, \"payloads\": [{\"type\": \"BUYER_DISCOM_ALLOC\", \"values\": [14.2]}, {\"type\": \"BUYER_DISCOM_STATUS\", \"values\": [\"COMPLETED\"]}]}\n            ]\n          }\n        }\n      ],\n      \"contractAttributes\": {\n        \"@context\": \"https://schema.beckn.io/DEGContract/v2.0/context.jsonld\",\n        \"@type\": \"DEGContract\",\n        \"roles\": [\n          {\"role\": \"buyer\", \"participantId\": \"buyerapp.example.com\"},\n          {\"role\": \"seller\", \"participantId\": \"sellerapp.example.com\"},\n          {\"role\": \"buyerDiscom\", \"participantId\": \"buyer-discom-ledger.example.com\"},\n          {\"role\": \"sellerDiscom\", \"participantId\": \"seller-discom-ledger.example.com\"}\n        ],\n        \"policy\": {\n          \"url\": \"https://raw.githubusercontent.com/beckn/DEG/refs/heads/main/specification/policies/p2p_trading_ies_wave2_revenue.rego\",\n          \"queryPath\": \"data.deg.contracts.p2p_trading\"\n        }\n      },\n      \"participants\": [\n        {\"role\": \"seller\", \"participantId\": \"sellerapp.example.com\", \"participantAttributes\": {\"@context\": \"https://schema.beckn.io/EnergyCustomer/v2.0/context.jsonld\", \"@type\": \"EnergyCustomer\", \"meterId\": \"TEST_METER_SELLER_001\", \"utilityId\": \"TEST_DISCOM_SELLER\", \"utilityCustomerId\": \"TEST_CUST_SELLER_001\", \"platformUri\": \"http://sellerapp.example.com:9000\"}},\n        {\"role\": \"buyer\", \"participantId\": \"buyerapp.example.com\", \"participantAttributes\": {\"@context\": \"https://schema.beckn.io/EnergyCustomer/v2.0/context.jsonld\", \"@type\": \"EnergyCustomer\", \"meterId\": \"TEST_METER_BUYER_001\", \"utilityId\": \"TEST_DISCOM_BUYER\", \"utilityCustomerId\": \"TEST_CUST_BUYER_001\", \"platformUri\": \"http://buyerapp.example.com:9000\"}},\n        {\"role\": \"buyerDiscom\", \"participantId\": \"buyer-discom-ledger.example.com\", \"participantAttributes\": {\"@context\": \"https://schema.beckn.io/DiscomLedgerProvider/v1.0/context.jsonld\", \"@type\": \"DiscomLedgerProvider\", \"utilityId\": \"TEST_DISCOM_BUYER\", \"ledgerUri\": \"{{ledger_host_buyer}}/bap/receiver\"}},\n        {\"role\": \"sellerDiscom\", \"participantId\": \"seller-discom-ledger.example.com\", \"participantAttributes\": {\"@context\": \"https://schema.beckn.io/DiscomLedgerProvider/v1.0/context.jsonld\", \"@type\": \"DiscomLedgerProvider\", \"utilityId\": \"TEST_DISCOM_SELLER\", \"ledgerUri\": \"{{ledger_host_seller}}/bpp/receiver\"}}\n      ]\n    }\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
