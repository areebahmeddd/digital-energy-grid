{
    "@context": {
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "skos": "http://www.w3.org/2004/02/skos/core#",
        "espi": "http://naesb.org/espi#",
        "energy": "https://schema.beckn.io/energy/"
    },
    "@graph": [
        {
            "@id": "energy:BillingSummaryCredential",
            "@type": "rdfs:Class",
            "rdfs:label": "Billing Summary Credential",
            "rdfs:comment": "A W3C Verifiable Credential containing aggregated billing period data. Uses ESPI/Green Button types (UsageSummary, SummaryMeasurement, LineItem) for the billing payload. Customer identity terms (customerProfile, customerNumber, meterNumber, meterType, idRef) are imported from the shared DEG CustomerProfile context."
        },
        {
            "@id": "energy:billingSummary",
            "@type": "rdf:Property",
            "rdfs:label": "billing summary",
            "rdfs:comment": "Container for ESPI billing summary data within a credential subject."
        },
        {
            "@id": "energy:timeZone",
            "@type": "rdf:Property",
            "rdfs:label": "time zone",
            "rdfs:comment": "IANA time-zone identifier for the meter location. Not an ESPI property — added for demand-forecasting models that need local solar time.",
            "rdfs:range": { "@id": "xsd:string" }
        }
    ]
}
