{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schema.beckn.io/billing-summary-vc/schema.json",
    "title": "Billing Summary Credential Schema",
    "description": "JSON Schema for the Billing Summary Verifiable Credential. Combines customer identity (customerProfile) with aggregated billing period data (billingSummary) containing costs and consumption totals, aligned with Green Button (ESPI/NAESB) UsageSummary semantics within a single W3C Verifiable Credential (VC Data Model 2.0). Issued by the utility; consumed by credit-check apps, program eligibility services, and energy analytics platforms.",
    "type": "object",
    "required": [
        "@context",
        "id",
        "type",
        "issuer",
        "validFrom",
        "credentialSubject"
    ],
    "properties": {
        "@context": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "contains": {
                "const": "https://www.w3.org/ns/credentials/v2"
            },
            "minItems": 2
        },
        "id": {
            "type": "string",
            "format": "uri",
            "pattern": "^urn:uuid:[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
            "description": "Unique identifier for the credential in URN UUID format"
        },
        "type": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "contains": {
                "const": "BillingSummaryCredential"
            },
            "minItems": 2
        },
        "issuer": {
            "type": "object",
            "required": ["id", "type", "name", "issuedBy", "subjectId"],
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uri",
                    "description": "DID of the issuing distribution utility"
                },
                "type": {
                    "type": "string",
                    "const": "idRef",
                    "description": "Identity reference type"
                },
                "name": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Name of the distribution utility"
                },
                "issuedBy": {
                    "type": "string",
                    "format": "uri",
                    "description": "DID or URI of the issuing authority"
                },
                "subjectId": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Regulatory registration number of the issuing utility"
                }
            }
        },
        "validFrom": {
            "type": "string",
            "format": "date-time",
            "description": "Date and time from which the credential is valid (W3C VC Data Model 2.0)"
        },
        "validUntil": {
            "type": "string",
            "format": "date-time",
            "description": "Date and time until which the credential is valid (W3C VC Data Model 2.0)"
        },
        "credentialStatus": {
            "type": "object",
            "required": ["id", "type", "statusPurpose"],
            "description": "Revocation status information for the credential using DeDi registry",
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL to query the revocation status of the credential via DeDi registry"
                },
                "type": {
                    "type": "string",
                    "const": "dedi",
                    "description": "Type of status check mechanism (DeDi)"
                },
                "statusPurpose": {
                    "type": "string",
                    "enum": ["revocation", "suspension"],
                    "description": "Purpose of the credential status entry"
                },
                "statusListCredential": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL of the DeDi status list credential used for lookup"
                }
            }
        },
        "credentialSubject": {
            "type": "object",
            "description": "Single subject with customerProfile (identity) and billingSummary (aggregated billing data) as equal-level properties.",
            "required": ["customerProfile", "billingSummary"],
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uri",
                    "description": "Optional DID of the customer/credential subject"
                },
                "customerProfile": {
                    "$ref": "#/$defs/CustomerProfile"
                },
                "billingSummary": {
                    "$ref": "#/$defs/BillingSummary"
                }
            }
        },
        "proof": {
            "type": "object",
            "required": ["type", "created", "verificationMethod", "proofPurpose", "proofValue"],
            "properties": {
                "type": {
                    "type": "string",
                    "description": "Cryptographic signature type (e.g., Ed25519Signature2020)"
                },
                "created": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Timestamp when the proof was created"
                },
                "verificationMethod": {
                    "type": "string",
                    "format": "uri",
                    "description": "URI of the verification method/public key"
                },
                "proofPurpose": {
                    "type": "string",
                    "enum": ["assertionMethod", "authentication"],
                    "description": "Purpose of the proof"
                },
                "proofValue": {
                    "type": "string",
                    "minLength": 1,
                    "description": "The cryptographic signature value"
                }
            }
        }
    },
    "$defs": {
        "CustomerProfile": {
            "type": "object",
            "description": "Core customer identity: customer number, meter number, masked ID",
            "required": ["customerNumber", "meterNumber", "meterType"],
            "properties": {
                "customerNumber": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Full customer account number assigned by the utility"
                },
                "meterNumber": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 50,
                    "description": "Unique meter serial number"
                },
                "meterType": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Type of electricity meter installed (e.g., Smart, Conventional, Prepaid, Bidirectional, Forward, Reverse)"
                },
                "maskedIdType": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Type of government-issued ID that has been masked (e.g., 'SSN', 'Passport', 'NationalID')"
                },
                "maskedIdNumber": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Masked government ID for privacy-preserving verification (e.g., 'XXXX-XXXX-1234')"
                }
            }
        },
        "BillingSummary": {
            "type": "object",
            "description": "Aggregated billing summary data for a single meter, using Green Button (ESPI/NAESB) UsageSummary semantics.",
            "required": [
                "serviceKind",
                "timeZone",
                "currency",
                "coveragePeriod",
                "billingPeriods"
            ],
            "properties": {
                "serviceKind": {
                    "type": "string",
                    "description": "Kind of service provided (ESPI: ServiceKind).",
                    "enum": [
                        "electricity",
                        "gas",
                        "water"
                    ]
                },
                "timeZone": {
                    "type": "string",
                    "description": "IANA time-zone identifier for the meter location (e.g., \"America/Los_Angeles\").",
                    "examples": [
                        "Asia/Kolkata",
                        "America/Los_Angeles"
                    ]
                },
                "currency": {
                    "type": "string",
                    "description": "ISO 4217 currency code for all monetary values in this credential.",
                    "examples": [
                        "USD",
                        "EUR",
                        "INR"
                    ]
                },
                "coveragePeriod": {
                    "type": "object",
                    "description": "Summary date range of the billing data contained in this credential.",
                    "required": [
                        "start",
                        "end"
                    ],
                    "properties": {
                        "start": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Start of the coverage period (ISO 8601)"
                        },
                        "end": {
                            "type": "string",
                            "format": "date-time",
                            "description": "End of the coverage period (ISO 8601)"
                        }
                    }
                },
                "billingPeriods": {
                    "type": "array",
                    "minItems": 1,
                    "description": "Array of billing period summaries. Each entry represents one billing cycle (typically monthly).",
                    "items": {
                        "type": "object",
                        "description": "A single billing period summary (ESPI: UsageSummary + IntervalReading from billing-granularity data).",
                        "required": [
                            "period",
                            "billAmount",
                            "consumption"
                        ],
                        "properties": {
                            "period": {
                                "type": "object",
                                "description": "Billing period boundaries (ESPI: billingPeriod / DateTimeInterval).",
                                "required": [
                                    "start",
                                    "duration"
                                ],
                                "properties": {
                                    "start": {
                                        "type": "string",
                                        "format": "date-time",
                                        "description": "Start of the billing period (ISO 8601)"
                                    },
                                    "duration": {
                                        "type": "integer",
                                        "minimum": 0,
                                        "description": "Duration of the billing period in seconds"
                                    }
                                }
                            },
                            "billAmount": {
                                "type": "number",
                                "description": "Total bill amount for this period in the credential's currency (ESPI: billLastPeriod). In integer mode (Green Button compatible), value is in thousandths of the currency unit. In decimal mode, value is the direct currency amount."
                            },
                            "consumption": {
                                "type": "object",
                                "description": "Total consumption for this billing period (ESPI: overallConsumptionLastPeriod).",
                                "required": [
                                    "value",
                                    "uom"
                                ],
                                "properties": {
                                    "value": {
                                        "type": "number",
                                        "description": "Consumption value. In integer mode, multiply by 10^powerOfTenMultiplier. In decimal mode, represents the physical quantity directly."
                                    },
                                    "uom": {
                                        "type": "string",
                                        "description": "Unit of measure for the consumption value.",
                                        "enum": [
                                            "Wh",
                                            "kWh",
                                            "W",
                                            "kW",
                                            "VA",
                                            "VAr",
                                            "V",
                                            "A",
                                            "Hz",
                                            "J",
                                            "m3"
                                        ]
                                    },
                                    "powerOfTenMultiplier": {
                                        "type": "integer",
                                        "default": 0,
                                        "description": "Power-of-ten multiplier for the consumption value. Defaults to 0."
                                    }
                                }
                            },
                            "additionalCosts": {
                                "type": "number",
                                "description": "Additional charges, surcharges, or fees for this period (ESPI: costAdditionalLastPeriod). Same currency encoding as billAmount."
                            },
                            "qualityOfReading": {
                                "type": "string",
                                "description": "Quality of the reading data for this billing period (ESPI: QualityOfReading).",
                                "enum": [
                                    "valid",
                                    "manuallyEdited",
                                    "estimatedUsingReferenceDay",
                                    "estimatedUsingLinearInterpolation",
                                    "questionable",
                                    "derived",
                                    "projected",
                                    "mixed",
                                    "raw",
                                    "normalizedForWeather",
                                    "other",
                                    "validated",
                                    "verified"
                                ]
                            },
                            "lineItems": {
                                "type": "array",
                                "description": "Itemised breakdown of charges and credits for this billing period (ESPI: costAdditionalDetailLastPeriod / LineItem). The sum of all lineItems amounts should reconcile with billAmount.",
                                "items": {
                                    "type": "object",
                                    "description": "A single charge or credit line item (ESPI: LineItem).",
                                    "required": [
                                        "itemKind",
                                        "amount"
                                    ],
                                    "properties": {
                                        "itemKind": {
                                            "type": "string",
                                            "description": "Classification of the charge or credit (ESPI: ItemKind). ESPI codes — 1: energyGenerationFee, 2: energyDeliveryFee, 3: energyUsageFee, 4: administrativeFee, 5: tax, 6: energyGenerationCredit, 7: energyDeliveryCredit, 8: administrativeCredit, 9: payment, 10: information.",
                                            "enum": [
                                                "energyGenerationFee",
                                                "energyDeliveryFee",
                                                "energyUsageFee",
                                                "administrativeFee",
                                                "tax",
                                                "energyGenerationCredit",
                                                "energyDeliveryCredit",
                                                "administrativeCredit",
                                                "payment",
                                                "information"
                                            ]
                                        },
                                        "amount": {
                                            "type": "number",
                                            "description": "Amount for this line item in the credential's currency. Same encoding as billAmount (integer mode: thousandths of currency unit; decimal mode: direct). Negative values represent credits."
                                        },
                                        "note": {
                                            "type": "string",
                                            "description": "Human-readable description of the charge or credit (ESPI: LineItem.note)."
                                        },
                                        "unitCost": {
                                            "type": "number",
                                            "description": "Per-unit cost for this line item (e.g., price per kWh). Same currency encoding as amount (ESPI: LineItem.unitCost)."
                                        },
                                        "itemPeriod": {
                                            "type": "object",
                                            "description": "Time period this line item covers, if different from the billing period (ESPI: LineItem.itemPeriod).",
                                            "required": [
                                                "start",
                                                "duration"
                                            ],
                                            "properties": {
                                                "start": {
                                                    "type": "string",
                                                    "format": "date-time",
                                                    "description": "Start of the item period (ISO 8601)"
                                                },
                                                "duration": {
                                                    "type": "integer",
                                                    "minimum": 0,
                                                    "description": "Duration of the item period in seconds"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
